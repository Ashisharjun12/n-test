# Docker Compose reads this file from the repo root.
# Copy to .env and fill in secrets before: docker compose up -d --build

# ── Ports ──
CLIENT_PORT=80
BACKEND_PORT=3000

# ── Client build (baked into image at build time) ──
# Use /api/v1 when nginx proxies /api → backend (default setup)
VITE_API_URL=/api/v1

# ── Backend ──
PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://mongo:27017/nero

# Allowed browser origins (comma-separated). Include your public URL.
CLIENT_ORIGIN=http://localhost,http://localhost:80

JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=7d
REFRESH_SECRET=change-me-too
REFRESH_EXPIRES_IN=30d

REDIS_URI=

STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

CLOUDINARY_SECRET=
CLOUDINARY_API_KEY=
CLOUDINARY_CLOUD_NAME=
